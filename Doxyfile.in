FILE_PATTERNS = *.hpp *.md

EXTRACT_ALL = NO
HIDE_UNDOC_RELATIONS = YES
HIDE_UNDOC_CLASSES = YES
USE_MDFILE_AS_MAINPAGE = ./files_for_doxygen/README.md
PROJECT_NAME = "Any++"

GENERATE_HTML = YES
GENERATE_LATEX = NO

WARN_IF_UNDOCUMENTED = NO
OUTPUT_DIRECTORY = ./doxygen/
INPUT = bit_factory/ docs/ ./files_for_doxygen/
EXAMPLE_PATH = examples/inline_mode/

